---
import type { Team } from '../lib/mock/teams';
import { getTeamFlagAlt, getTeamFlagHref } from '../lib/teams/flags';

interface Props {
  teamId: string;
  team?: Team;
  teamName?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { teamId, team, teamName: teamNameProp, size = 'md' } = Astro.props;
const teamName = teamNameProp ?? team?.name;
const flagHref = getTeamFlagHref(teamId);
const flagAlt = getTeamFlagAlt(teamId, teamName);
---

<span
  class:list={['country-flag', `country-flag--${size}`]}
  data-team-id={teamId}
  role="img"
  aria-label={flagAlt}
>
  <svg class="country-flag__svg" aria-hidden="true">
    <use href={flagHref} />
  </svg>
</span>
