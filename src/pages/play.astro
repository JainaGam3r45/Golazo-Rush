---
import Layout from '../layouts/Layout.astro';
import GameShell from '../components/GameShell.astro';
import { getTeams } from '../lib/data/teams';

const teams = await getTeams();
const teamNames = Object.fromEntries(teams.map((team) => [team.id, team.name]));
---

<Layout title="Golazo Rush — Jugar" immersive>
  <GameShell teams={teams} teamNames={teamNames} />
</Layout>

<script>
  import { isSoundMuted, setSoundMuted } from '../lib/storage/soundPreference';
  import {
    isFullscreenSupported,
    isShellFullscreen,
    enterFullscreen,
    wireFullscreenScaleRefresh,
  } from '../lib/match/fullscreen';
  import { formatModeLabel } from '../lib/match/formats';
  import { insforge, isInsForgeConfigured } from '../lib/insforge';
  import { getPublicGameServerUrl, toHttpUrl } from '../lib/match/onlineProtocol';
  import { resolveOnlineAccessToken } from '../lib/match/onlineAuth';
  import { CHANNELS } from '../lib/realtime/channels';
  import {
    subscribe,
    onEvent,
    onPresenceJoin,
    onPresenceLeave,
    isRealtimeAvailable,
  } from '../lib/realtime/client';
  import {
    appendLobbyMatch,
    removeLobbyMatch,
    renderLobbyPresence,
  } from '../lib/realtime/handlers';
  import { formatMatchClock } from '../lib/match/formatMatchClock';
  import { getAuthState, hydrateSession, subscribeAuth } from '../lib/auth/session';
  import { DEFAULT_DURATION } from '../lib/match/setup';
  import { createShellController } from '../lib/match/shellController';
  import { mapOnlineUiToShell } from '../lib/match/shellState';
  import { createServerHealthMonitor } from '../lib/match/serverHealth';
  import {
    setActiveGameSuspended,
    clearGameplayKeysSuspended,
    getActivePhaserGame,
  } from '../lib/match/inputSuspend';
  import { refreshGameScale } from '../lib/match/gameBridge';
  import { sendRoomChat } from '../lib/match/privateRoomApi';
  import { chatMessageDedupeKey } from '../lib/match/lineup';

  const playDataEl = document.getElementById('play-data');
  const teamNames = JSON.parse(playDataEl?.dataset.teamNames ?? '{}');
  const shellRoot = document.getElementById('game-shell');
  if (!shellRoot) throw new Error('game-shell missing');

  let activeMatchId = null;
  let submitInFlight = false;
  const submittedMatchIds = new Set();
  let matchEndedHandler = null;
  let stoppageHandler = null;
  let currentUser = null;
  let stopInFlight = null;
  const playUnsubscribes = [];
  const matchChannelUnsubscribes = [];
  let chatRoomId = null;
  let chatOpen = false;
  let unreadChat = 0;
  const seenChatKeys = new Set();
  let lastHealthOffline = false;

  const shell = createShellController({ root: shellRoot });
  const health = createServerHealthMonitor({
    onChange(snap) {
      const el = shellRoot.querySelector('[data-health-value]');
      if (!el) return;
      const labels = {
        online: 'Online',
        connecting: 'Conectando…',
        degraded: 'Degradado',
        offline: 'Offline',
        unknown: 'Desconocido',
      };
      el.textContent = labels[snap.status] ?? snap.status;
      el.dataset.health = snap.status;
      lastHealthOffline = snap.status === 'offline';
      const onlineCard = shellRoot.querySelector('[data-hub-card="online"]');
      if (onlineCard && shell.getHubSubview() === 'cards') {
        // keep card clickable; actions inside OnlineRoomPanel still work when online
      }
      const createBtn = document.querySelector('[data-online-create]');
      const joinBtn = document.querySelector('[data-online-join]');
      if (createBtn) createBtn.disabled = lastHealthOffline;
      if (joinBtn) joinBtn.disabled = lastHealthOffline;
    },
  });

  const fsWire = wireFullscreenScaleRefresh((active) => {
    updateReenterChip(active);
    const menuFs = shellRoot.querySelector('[data-menu-fullscreen]');
    if (menuFs) menuFs.hidden = active || !isFullscreenSupported();
  });

  function getTeamName(id) {
    return teamNames[id] ?? id;
  }

  function updateReenterChip(fsActive) {
    const chip = shellRoot.querySelector('[data-reenter-fs]');
    if (!chip) return;
    const inGame =
      shell.getState() === 'match' ||
      shell.getState() === 'hub' ||
      shell.getState() === 'room' ||
      shell.getState() === 'results';
    chip.hidden = !inGame || fsActive || shellRoot.classList.contains('game-shell--immersive-css');
  }

  function setChatVisible(open) {
    chatOpen = open;
    const drawer = shellRoot.querySelector('[data-game-chat]');
    if (drawer) {
      drawer.classList.toggle('game-chat--open', open);
    }
    for (const btn of shellRoot.querySelectorAll('[data-chat-toggle], [data-chat-toggle-match]')) {
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    }
    setActiveGameSuspended(open && shell.getState() === 'match');
    refreshGameScale();
    if (open) {
      unreadChat = 0;
      updateChatBadge();
      shellRoot.querySelector('[data-chat-input]')?.focus();
    } else if (shell.getState() === 'match') {
      const menu = shellRoot.querySelector('[data-game-menu]');
      if (menu?.hidden !== false) {
        const game = getActivePhaserGame();
        if (game && !chatOpen) clearGameplayKeysSuspended(game);
      }
    } else {
      const game = getActivePhaserGame();
      if (game) clearGameplayKeysSuspended(game);
    }
  }

  function updateChatBadge() {
    for (const badge of shellRoot.querySelectorAll('[data-chat-badge], [data-chat-badge-match]')) {
      badge.hidden = unreadChat <= 0;
      badge.textContent = unreadChat > 9 ? '9+' : String(unreadChat);
    }
  }

  function updateChatToggleVisibility() {
    const show =
      Boolean(chatRoomId) &&
      (shell.getState() === 'room' ||
        shell.getState() === 'match' ||
        shell.getState() === 'results' ||
        shell.getState() === 'connectingMatch');
    for (const btn of shellRoot.querySelectorAll('[data-chat-toggle]')) {
      btn.hidden = !show || shell.getState() === 'match';
    }
    const quick = shellRoot.querySelector('[data-chat-quick]');
    if (quick) quick.hidden = shell.getState() !== 'match';
  }

  function appendShellChat(msg) {
    const key = chatMessageDedupeKey(msg);
    if (seenChatKeys.has(key)) return;
    seenChatKeys.add(key);
    const list = shellRoot.querySelector('[data-chat-list]');
    const empty = shellRoot.querySelector('[data-chat-empty]');
    if (!list) return;
    if (empty) empty.hidden = true;
    const li = document.createElement('li');
    const meta = document.createElement('span');
    meta.style.color = 'var(--accent)';
    meta.style.fontWeight = '600';
    const label = msg.displayLabel || msg.displayName || msg.userId?.slice?.(0, 8) || 'Jugador';
    meta.textContent = `${label}: `;
    li.append(meta, document.createTextNode(String(msg.body ?? '')));
    list.appendChild(li);
    list.scrollTop = list.scrollHeight;
    if (!chatOpen) {
      unreadChat += 1;
      updateChatBadge();
    }
  }

  function updateMuteButton(refreshVolume = false) {
    const muteBtn = shellRoot.querySelector('[data-mute]');
    if (!muteBtn) return;
    const muted = isSoundMuted();
    const label = muted ? 'Sonido' : 'Silenciar';
    muteBtn.setAttribute('aria-label', muted ? 'Activar sonido' : 'Silenciar sonido');
    muteBtn.setAttribute('title', label);
    muteBtn.classList.toggle('match-hud__icon-btn--active', muted);
    const onIcon = muteBtn.querySelector('[data-mute-icon-on]');
    const offIcon = muteBtn.querySelector('[data-mute-icon-off]');
    const labelEl = muteBtn.querySelector('[data-mute-label]');
    if (onIcon) onIcon.hidden = muted;
    if (offIcon) offIcon.hidden = !muted;
    if (labelEl) labelEl.textContent = label;
    if (refreshVolume) {
      void import('../game/audio/matchAudio').then((mod) => mod.refreshAmbientVolume());
    }
    const menuSound = shellRoot.querySelector('[data-menu-sound]');
    if (menuSound) menuSound.textContent = muted ? 'Activar sonido' : 'Silenciar sonido';
  }

  function setStoppageState(label, hint) {
    const stoppageEl = shellRoot.querySelector('[data-stoppage]');
    if (stoppageEl) stoppageEl.textContent = label || 'En juego';
    const helpHint = shellRoot.querySelector('[data-controls-help-hint]');
    if (helpHint && hint) helpHint.textContent = hint;
  }

  function setConnQuality(rttMs) {
    const el = shellRoot.querySelector('[data-conn-quality]');
    if (!el) return;
    if (typeof rttMs !== 'number') {
      el.hidden = true;
      return;
    }
    el.hidden = false;
    let quality = 'buena';
    if (rttMs > 180) quality = 'débil';
    else if (rttMs > 100) quality = 'estable';
    el.textContent = `Conexión: ${Math.round(rttMs)} ms · ${quality}`;
  }

  async function stopActiveMatch() {
    if (stopInFlight) {
      await stopInFlight;
      return;
    }
    stopInFlight = (async () => {
      const [{ destroyGame }, { stopMatchAudio }] = await Promise.all([
        import('../game/main'),
        import('../game/audio/matchAudio'),
      ]);
      destroyGame();
      stopMatchAudio();
    })().finally(() => {
      stopInFlight = null;
    });
    await stopInFlight;
  }

  async function teardownPlayPage() {
    health.dispose();
    fsWire.dispose();
    shell.dispose();
    setChatVisible(false);
    const [{ destroyGame }, { stopMatchAudio, disposeMatchAudio }] = await Promise.all([
      import('../game/main'),
      import('../game/audio/matchAudio'),
    ]);
    destroyGame();
    stopMatchAudio();
    disposeMatchAudio();
    unbindMatchEnded();
    unbindStoppage();
    for (const unsub of playUnsubscribes.splice(0)) unsub();
    for (const unsub of matchChannelUnsubscribes.splice(0)) unsub();
  }

  function showResultPanel(detail) {
    shell.setState('results');
    void stopActiveMatch();
    window.dispatchEvent(
      new CustomEvent('golazo:show-result', {
        detail: {
          homeTeamName: getTeamName(detail.homeTeamId),
          awayTeamName: getTeamName(detail.awayTeamId),
          homeScore: detail.homeScore,
          awayScore: detail.awayScore,
          durationSeconds: detail.durationSeconds,
        },
      }),
    );
  }

  function updateResultPanelSyncState(state) {
    window.dispatchEvent(new CustomEvent('golazo:result-sync', { detail: { state } }));
  }

  async function submitMatchResult(detail) {
    showResultPanel(detail);
    if (submittedMatchIds.has(detail.localMatchId)) return;
    if (submitInFlight) return;
    if (!currentUser) {
      updateResultPanelSyncState('guest');
      return;
    }
    submitInFlight = true;
    updateResultPanelSyncState('pending');
    try {
      let synced = false;
      let matchId = null;
      const gameServerUrl = getPublicGameServerUrl();
      if (gameServerUrl) {
        const resolved = await resolveOnlineAccessToken();
        if (resolved.token) {
          try {
            const res = await fetch(`${toHttpUrl(gameServerUrl)}/record-result`, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                Authorization: `Bearer ${resolved.token}`,
              },
              body: JSON.stringify({
                homeTeamId: detail.homeTeamId,
                awayTeamId: detail.awayTeamId,
                homeScore: detail.homeScore,
                awayScore: detail.awayScore,
                durationSeconds: detail.durationSeconds,
              }),
            });
            if (res.ok) {
              const data = await res.json().catch(() => null);
              synced = true;
              if (data && typeof data === 'object' && data.matchId) {
                matchId = String(data.matchId);
              }
            }
          } catch {
            // Fall through.
          }
        }
      }
      if (!synced && !gameServerUrl && isInsForgeConfigured && insforge) {
        const { data, error } = await insforge.functions.invoke('record-match-result', {
          body: {
            homeTeamId: detail.homeTeamId,
            awayTeamId: detail.awayTeamId,
            homeScore: detail.homeScore,
            awayScore: detail.awayScore,
            durationSeconds: detail.durationSeconds,
          },
        });
        if (!error) {
          synced = true;
          if (data && typeof data === 'object' && 'matchId' in data) {
            matchId = String(data.matchId);
          }
        }
      }
      if (synced) {
        submittedMatchIds.add(detail.localMatchId);
        if (matchId) {
          activeMatchId = matchId;
          await subscribeToMatchChannel(activeMatchId);
        }
      }
      updateResultPanelSyncState(synced ? 'synced' : gameServerUrl || isInsForgeConfigured ? 'offline' : 'local');
    } finally {
      submitInFlight = false;
    }
  }

  async function subscribeToMatchChannel(matchId) {
    if (!isRealtimeAvailable()) return;
    for (const unsub of matchChannelUnsubscribes.splice(0)) unsub();
    const channel = CHANNELS.match(matchId);
    const result = await subscribe(channel);
    if (!result.ok) return;
    matchChannelUnsubscribes.push(onEvent('match_joined', () => {}));
    matchChannelUnsubscribes.push(
      onEvent('match_finished', (payload) => {
        if (String(payload.matchId) === matchId) {
          // match channel update
        }
      }),
    );
  }

  function bindMatchEnded(handler) {
    unbindMatchEnded();
    matchEndedHandler = handler;
    window.addEventListener('golazo:match-ended', handler);
  }

  function unbindMatchEnded() {
    if (matchEndedHandler) {
      window.removeEventListener('golazo:match-ended', matchEndedHandler);
      matchEndedHandler = null;
    }
  }

  function bindStoppage() {
    unbindStoppage();
    stoppageHandler = (event) => {
      const detail = event.detail ?? {};
      setStoppageState(detail.label ?? 'En juego', detail.hint);
    };
    window.addEventListener('golazo:match-stoppage', stoppageHandler);
  }

  function unbindStoppage() {
    if (stoppageHandler) {
      window.removeEventListener('golazo:match-stoppage', stoppageHandler);
      stoppageHandler = null;
    }
  }

  async function abandonMatch() {
    await stopActiveMatch();
    unbindMatchEnded();
    unbindStoppage();
    setChatVisible(false);
    if (shell.getMatchMode() === 'online') {
      window.dispatchEvent(new CustomEvent('golazo:shell-abandon-match'));
      shell.setState('hub');
      shell.setHubSubview('online');
    } else {
      shell.setMatchMode('cpu');
      shell.setState('hub');
      shell.setHubSubview('cpuPreview');
    }
  }

  async function goToHub() {
    await stopActiveMatch();
    unbindMatchEnded();
    unbindStoppage();
    setChatVisible(false);
    shell.setMatchMode(null);
    shell.setHubSubview('cards');
    shell.setState('hub');
  }

  async function enterHub(withFullscreen) {
    if (withFullscreen && isFullscreenSupported()) {
      const ok = await enterFullscreen(shellRoot);
      if (!ok) shell.setCssImmersive(true);
    } else {
      shell.setCssImmersive(true);
    }
    health.start();
    shell.setState('hub');
    shell.setHubSubview('cards');
    updateReenterChip(isShellFullscreen(shellRoot));
  }

  function wireShellChrome() {
    shellRoot.querySelector('[data-enter-game]')?.addEventListener('click', () => {
      void enterHub(true);
    });
    shellRoot.querySelector('[data-enter-without-fs]')?.addEventListener('click', () => {
      void enterHub(false);
    });
    shellRoot.querySelector('[data-reenter-fs]')?.addEventListener('click', async () => {
      const ok = await enterFullscreen(shellRoot);
      if (!ok) shell.setCssImmersive(true);
      updateReenterChip(isShellFullscreen(shellRoot));
    });

    shellRoot.querySelector('[data-hub-card="cpu"]')?.addEventListener('click', () => {
      shell.setMatchMode('cpu');
      shell.setHubSubview('cpuSelect');
    });
    shellRoot.querySelector('[data-hub-card="online"]')?.addEventListener('click', () => {
      shell.setMatchMode('online');
      shell.setHubSubview('online');
      window.dispatchEvent(new CustomEvent('golazo:play-mode', { detail: { mode: 'online' } }));
    });
    shellRoot.querySelector('[data-hub-back]')?.addEventListener('click', () => {
      shell.setHubSubview('cards');
      shell.setMatchMode(null);
    });
    shellRoot.querySelector('[data-hub-back-preview]')?.addEventListener('click', () => {
      shell.setHubSubview('cpuSelect');
    });
    shellRoot.querySelector('[data-hub-back-online]')?.addEventListener('click', () => {
      shell.setHubSubview('cards');
      shell.setMatchMode(null);
    });
    shellRoot.querySelector('[data-results-to-hub]')?.addEventListener('click', () => {
      void goToHub();
    });
    shellRoot.querySelector('[data-shell-error-hub]')?.addEventListener('click', () => {
      void goToHub();
    });
    shellRoot.querySelector('[data-shell-error-retry]')?.addEventListener('click', () => {
      shell.setState('hub');
      shell.setHubSubview('online');
      window.dispatchEvent(new CustomEvent('golazo:shell-retry-session'));
    });

    for (const btn of shellRoot.querySelectorAll('[data-chat-toggle], [data-chat-toggle-match]')) {
      btn.addEventListener('click', () => setChatVisible(!chatOpen));
    }
    shellRoot.querySelector('[data-chat-close]')?.addEventListener('click', () => setChatVisible(false));

    shellRoot.querySelector('[data-chat-form]')?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const input = shellRoot.querySelector('[data-chat-input]');
      const message = input?.value?.trim() ?? '';
      if (!message || !chatRoomId) return;
      const errEl = shellRoot.querySelector('[data-chat-error]');
      if (errEl) {
        errEl.hidden = true;
        errEl.textContent = '';
      }
      const result = await sendRoomChat(chatRoomId, message);
      if (!result.ok) {
        if (errEl) {
          errEl.hidden = false;
          errEl.textContent = result.error.message;
        }
        return;
      }
      if (input) input.value = '';
    });

    for (const btn of shellRoot.querySelectorAll('[data-chat-quick-msg]')) {
      btn.addEventListener('click', async () => {
        const message = btn.getAttribute('data-chat-quick-msg');
        if (!message || !chatRoomId) return;
        await sendRoomChat(chatRoomId, message);
      });
    }

    shellRoot.querySelector('[data-match-menu]')?.addEventListener('click', () => {
      const menu = shellRoot.querySelector('[data-game-menu]');
      if (menu) menu.hidden = false;
      setActiveGameSuspended(true);
    });
    shellRoot.querySelector('[data-menu-resume]')?.addEventListener('click', () => {
      const menu = shellRoot.querySelector('[data-game-menu]');
      if (menu) menu.hidden = true;
      if (!chatOpen) {
        const game = getActivePhaserGame();
        if (game) clearGameplayKeysSuspended(game);
      }
    });
    shellRoot.querySelector('[data-menu-controls]')?.addEventListener('click', () => {
      const help = shellRoot.querySelector('[data-controls-help]');
      if (help) help.hidden = false;
    });
    shellRoot.querySelector('[data-controls-help-close]')?.addEventListener('click', () => {
      const help = shellRoot.querySelector('[data-controls-help]');
      if (help) help.hidden = true;
    });
    shellRoot.querySelector('[data-menu-sound]')?.addEventListener('click', async () => {
      const { unlockMatchAudio } = await import('../game/audio/matchAudio');
      unlockMatchAudio();
      setSoundMuted(!isSoundMuted());
      updateMuteButton(true);
    });
    shellRoot.querySelector('[data-menu-fullscreen]')?.addEventListener('click', async () => {
      await enterFullscreen(shellRoot);
      updateReenterChip(isShellFullscreen(shellRoot));
    });
    shellRoot.querySelector('[data-menu-abandon]')?.addEventListener('click', () => {
      const confirm = shellRoot.querySelector('[data-abandon-confirm]');
      if (confirm) confirm.hidden = false;
    });
    shellRoot.querySelector('[data-abandon-confirm-no]')?.addEventListener('click', () => {
      const confirm = shellRoot.querySelector('[data-abandon-confirm]');
      if (confirm) confirm.hidden = true;
    });
    shellRoot.querySelector('[data-abandon-confirm-yes]')?.addEventListener('click', () => {
      const confirm = shellRoot.querySelector('[data-abandon-confirm]');
      const menu = shellRoot.querySelector('[data-game-menu]');
      if (confirm) confirm.hidden = true;
      if (menu) menu.hidden = true;
      void abandonMatch();
    });

    shellRoot.querySelector('[data-mute]')?.addEventListener('click', async () => {
      const { unlockMatchAudio } = await import('../game/audio/matchAudio');
      unlockMatchAudio();
      setSoundMuted(!isSoundMuted());
      updateMuteButton(true);
    });

    updateMuteButton();
  }

  function initPlayFlow() {
    window.addEventListener('golazo:team-selected', () => {
      if (shell.getMatchMode() === 'cpu') {
        const preview = shellRoot.querySelector('[data-match-preview]');
        if (preview) preview.hidden = false;
        shell.setHubSubview('cpuPreview');
      }
    });

    window.addEventListener('golazo:start-match', async (event) => {
      if (shell.getMatchMode() !== 'cpu') return;
      if (stopInFlight) await stopInFlight;
      const setup = event.detail;
      shell.setState('match');
      updateChatToggleVisibility();

      const clockEl = document.getElementById('match-clock');
      if (clockEl) clockEl.textContent = formatMatchClock(setup.durationSeconds);
      const modeEl = document.getElementById('match-mode');
      if (modeEl) modeEl.textContent = formatModeLabel(setup.formatId ?? '5v5');
      setStoppageState('En juego', 'En juego: controla tu jugador y busca el gol.');
      const homeName = document.getElementById('hud-home-name');
      const awayName = document.getElementById('hud-away-name');
      if (homeName) homeName.textContent = getTeamName(setup.homeTeamId);
      if (awayName) awayName.textContent = getTeamName(setup.awayTeamId);
      const scoreHome = document.getElementById('score-home');
      const scoreAway = document.getElementById('score-away');
      if (scoreHome) scoreHome.textContent = '0';
      if (scoreAway) scoreAway.textContent = '0';

      const [{ startGame }, { unlockMatchAudio }] = await Promise.all([
        import('../game/main'),
        import('../game/audio/matchAudio'),
      ]);
      unlockMatchAudio();
      startGame('game-container', setup);
      bindStoppage();
      bindMatchEnded((e) => submitMatchResult(e.detail));
    });

    window.addEventListener('golazo:online-match-start', async (event) => {
      if (shell.getMatchMode() !== 'online' && shell.getState() !== 'room' && shell.getState() !== 'connectingMatch') {
        shell.setMatchMode('online');
      }
      if (stopInFlight) await stopInFlight;
      const detail = event.detail;
      if (!detail?.roomId) return;

      if (!getPublicGameServerUrl()) {
        setStoppageState(
          'Servidor no configurado',
          'Falta PUBLIC_GAME_SERVER_URL. No se puede conectar al partido online.',
        );
        window.dispatchEvent(
          new CustomEvent('golazo:online-conn', {
            detail: { status: 'error', detail: 'PUBLIC_GAME_SERVER_URL no configurada', at: Date.now() },
          }),
        );
        return;
      }

      const resolved = await resolveOnlineAccessToken();
      if (!resolved.token) {
        setStoppageState(
          'Sesión requerida',
          resolved.reason ?? 'No hay access token para conectar al partido online.',
        );
        window.dispatchEvent(
          new CustomEvent('golazo:online-conn', {
            detail: { status: 'error', detail: resolved.reason ?? 'Sin sesión', at: Date.now() },
          }),
        );
        return;
      }

      chatRoomId = detail.roomId;
      shell.setMatchMode('online');
      shell.setState('connectingMatch');
      updateChatToggleVisibility();

      const clockEl = document.getElementById('match-clock');
      if (clockEl) clockEl.textContent = formatMatchClock(detail.durationSeconds ?? DEFAULT_DURATION);
      const modeEl = document.getElementById('match-mode');
      if (modeEl) {
        modeEl.textContent =
          detail.role === 'spectator' ? 'Espectando · conectando' : '11v11 Online · conectando';
      }
      setStoppageState(
        detail.role === 'spectator' ? 'Espectando' : 'Conectando',
        detail.role === 'spectator'
          ? 'Modo espectador: conectando a la retransmisión…'
          : 'Conectando al servidor de partida…',
      );
      const homeName = document.getElementById('hud-home-name');
      const awayName = document.getElementById('hud-away-name');
      if (homeName) homeName.textContent = getTeamName(detail.homeTeamId);
      if (awayName) awayName.textContent = getTeamName(detail.awayTeamId);
      const scoreHome = document.getElementById('score-home');
      const scoreAway = document.getElementById('score-away');
      if (scoreHome) scoreHome.textContent = '0';
      if (scoreAway) scoreAway.textContent = '0';

      shell.setState('match');

      const [{ startOnlineGame }, { unlockMatchAudio }] = await Promise.all([
        import('../game/online/main'),
        import('../game/audio/matchAudio'),
      ]);
      unlockMatchAudio();
      startOnlineGame('game-container', detail);
      bindStoppage();
      bindMatchEnded((e) => {
        showResultPanel(e.detail);
        updateResultPanelSyncState('local');
      });
    });

    window.addEventListener('golazo:online-conn', (event) => {
      if (shell.getMatchMode() !== 'online') return;
      const status = event.detail?.status;
      const modeEl = document.getElementById('match-mode');
      const spectating = modeEl?.textContent?.startsWith('Espectando');
      if (modeEl && status) {
        if (spectating) {
          if (status === 'playing' || status === 'joined') modeEl.textContent = 'Espectando';
          else if (status === 'error') modeEl.textContent = 'Espectando · error';
        } else if (status === 'playing') modeEl.textContent = '11v11 Online';
        else if (status === 'joined') modeEl.textContent = '11v11 Online · en sala';
        else if (status === 'error') modeEl.textContent = '11v11 Online · error';
      }
      if (status === 'error' || status === 'closed') {
        if (event.detail?.detail) {
          setStoppageState('Error de conexión', String(event.detail.detail));
        }
        void stopActiveMatch();
        shell.setState('hub');
        shell.setHubSubview('online');
      }
    });

    window.addEventListener('golazo:online-ping', (event) => {
      if (shell.getMatchMode() !== 'online') return;
      setConnQuality(event.detail?.rttMs);
    });

    window.addEventListener('golazo:online-ui-state', (event) => {
      const onlineState = event.detail?.state;
      const hasActive = Boolean(event.detail?.hasActiveRoom);
      const badge = shellRoot.querySelector('[data-online-active-badge]');
      if (badge) badge.hidden = !hasActive;

      if (event.detail?.roomId) {
        chatRoomId = event.detail.roomId;
      }

      if (typeof onlineState === 'string') {
        const mapped = mapOnlineUiToShell(onlineState, shell.getState());
        if (mapped === 'room') {
          shell.setMatchMode('online');
          shell.setState('room');
        } else if (mapped === 'connectingMatch' && shell.getState() !== 'match') {
          shell.setState('connectingMatch');
        } else if (mapped === 'recoverableError' && shell.getState() === 'hub') {
          shell.setState('recoverableError');
          const msg = shellRoot.querySelector('[data-shell-error-msg]');
          if (msg && event.detail?.errorMsg) msg.textContent = event.detail.errorMsg;
        } else if (
          (onlineState === 'authenticatedIdle' ||
            onlineState === 'guest' ||
            onlineState === 'activeRoom') &&
          shell.getState() === 'room'
        ) {
          shell.setState('hub');
          shell.setHubSubview('online');
        }
      }
      updateChatToggleVisibility();
    });

    window.addEventListener('golazo:room-chat', (event) => {
      if (event.detail) {
        const msg = event.detail;
        appendShellChat({
          ...msg,
          userId: msg.userId,
          body: msg.body,
          displayLabel: msg.displayName,
        });
      }
    });

    window.addEventListener('golazo:room-chat-history', (event) => {
      const detail = event.detail;
      if (!detail?.messages?.length) return;
      for (const msg of detail.messages) {
        const key = chatMessageDedupeKey(msg);
        if (seenChatKeys.has(key)) continue;
        seenChatKeys.add(key);
        const list = shellRoot.querySelector('[data-chat-list]');
        const empty = shellRoot.querySelector('[data-chat-empty]');
        if (!list) continue;
        if (empty) empty.hidden = true;
        const li = document.createElement('li');
        const meta = document.createElement('span');
        meta.style.color = 'var(--accent)';
        meta.style.fontWeight = '600';
        const label = msg.displayName || msg.username || msg.userId?.slice?.(0, 8) || 'Jugador';
        meta.textContent = `${label}: `;
        li.append(meta, document.createTextNode(String(msg.body ?? '')));
        list.appendChild(li);
      }
      const list = shellRoot.querySelector('[data-chat-list]');
      if (list) list.scrollTop = list.scrollHeight;
    });

    window.addEventListener('golazo:restart-match', () => {
      void (async () => {
        await stopActiveMatch();
        unbindMatchEnded();
        unbindStoppage();
        if (shell.getMatchMode() === 'online') {
          shell.setState('hub');
          shell.setHubSubview('online');
          return;
        }
        shell.setState('hub');
        shell.setHubSubview('cpuPreview');
      })();
    });
  }

  async function wirePlayRealtime() {
    if (!isRealtimeAvailable()) return;
    const lobbyResult = await subscribe(CHANNELS.LOBBY);
    if (!lobbyResult.ok) return;
    let lobbyMembers = lobbyResult.members.map((m) => ({ presenceId: m.presenceId }));
    renderLobbyPresence(lobbyMembers, '[data-lobby-presence]');
    document.querySelector('[data-lobby-empty]')?.remove();
    playUnsubscribes.push(
      onPresenceJoin(({ member, meta }) => {
        if (meta.channel !== CHANNELS.LOBBY) return;
        lobbyMembers = [...lobbyMembers, { presenceId: member.presenceId }];
        renderLobbyPresence(lobbyMembers, '[data-lobby-presence]');
      }),
    );
    playUnsubscribes.push(
      onPresenceLeave(({ member, meta }) => {
        if (meta.channel !== CHANNELS.LOBBY) return;
        lobbyMembers = lobbyMembers.filter((m) => m.presenceId !== member.presenceId);
        renderLobbyPresence(lobbyMembers, '[data-lobby-presence]');
      }),
    );
    playUnsubscribes.push(
      onEvent('match_created', (payload) => {
        document.querySelector('[data-lobby-empty]')?.remove();
        appendLobbyMatch(payload, '[data-lobby-matches]');
      }),
    );
    playUnsubscribes.push(
      onEvent('match_finished', (payload) => {
        removeLobbyMatch(String(payload.matchId), '[data-lobby-matches]');
      }),
    );
  }

  async function wirePlaySession() {
    const sessionEl = shellRoot.querySelector('[data-play-session]');
    const bootStatus = shellRoot.querySelector('[data-boot-status]');
    const { fetchProfile } = await import('../lib/profile/store');

    subscribeAuth(async (state) => {
      currentUser = state.user;
      if (state.phase === 'hydrating' || state.phase === 'refreshing' || state.loading) {
        if (bootStatus) bootStatus.textContent = 'Comprobando sesión…';
        if (sessionEl) {
          sessionEl.textContent = 'Comprobando sesión…';
        }
        return;
      }
      if (state.user) {
        const profile = await fetchProfile(state.user.id);
        const name = profile?.display_name ?? state.user.name ?? 'Jugador';
        if (sessionEl) sessionEl.textContent = `Jugando como ${name}`;
      } else if (sessionEl) {
        sessionEl.innerHTML =
          'Puedes jugar <strong>Contra bots</strong> como invitado. <a href="/login?returnTo=%2Fplay">Inicia sesión</a> para Online 1v1 y guardar progreso.';
      }
    });

    await hydrateSession();
    currentUser = getAuthState().user;
    if (shell.getState() === 'boot') {
      shell.setState('entry');
    }
  }

  wireShellChrome();
  wirePlaySession();
  initPlayFlow();
  wirePlayRealtime();
  window.addEventListener('pagehide', () => {
    void teardownPlayPage();
  });
</script>
