---
import type { Team } from '../lib/mock/teams';
import { ALLOWED_DURATIONS } from '../lib/match/setup';

interface Props {
  teams: Team[];
}

const { teams } = Astro.props;
---

<section class="online-room" data-online-room hidden data-teams={JSON.stringify(teams)}>
  <div class="online-room__panel" data-online-view="hydratingSession" hidden>
    <div class="online-room__skeleton" aria-busy="true" aria-live="polite">
      <div class="online-room__skel-line"></div>
      <div class="online-room__skel-line online-room__skel-line--short"></div>
    </div>
    <p class="online-room__muted">Comprobando sesión…</p>
  </div>

  <div class="online-room__panel" data-online-view="guest" hidden>
    <h2 class="online-room__title">Online 1v1</h2>
    <p class="online-room__lead">Compite contra otro jugador. Requiere una cuenta.</p>
    <div class="online-room__cta">
      <a class="btn" href="/login">Iniciar sesión</a>
      <a class="btn-outline" href="/register">Crear cuenta</a>
    </div>
  </div>

  <div class="online-room__panel" data-online-view="recoverableError" hidden>
    <h2 class="online-room__title">Sesión</h2>
    <p class="online-room__error" data-online-error-msg role="alert"></p>
    <div class="online-room__cta">
      <button type="button" class="btn" data-online-retry-session>Reintentar sesión</button>
      <a class="btn-outline" href="/login">Iniciar sesión</a>
    </div>
  </div>

  <div class="online-room__panel" data-online-view="checkingActiveRoom" hidden>
    <p class="online-room__muted" aria-live="polite">Buscando sala activa…</p>
  </div>

  <div class="online-room__panel" data-online-view="authenticatedIdle" hidden>
    <h2 class="online-room__title">Online 1v1</h2>
    <p class="online-room__lead">Crea una sala privada o únete con un código de 6 caracteres.</p>
    <div class="online-room__entry-grid">
      <div class="online-room__card">
        <h3>Crear sala</h3>
        <label class="online-room__field">
          <span>Duración</span>
          <select data-online-duration>
            {
              ALLOWED_DURATIONS.map((seconds) => (
                <option value={seconds} selected={seconds === 180}>
                  {seconds / 60} min
                </option>
              ))
            }
          </select>
        </label>
        <button type="button" class="btn" data-online-create>Crear sala privada</button>
      </div>
      <div class="online-room__card">
        <h3>Unirse con código</h3>
        <label class="online-room__field">
          <span>Código</span>
          <input type="text" data-online-code maxlength="6" autocomplete="off" spellcheck="false" placeholder="ABC123" />
        </label>
        <button type="button" class="btn" data-online-join>Entrar a la sala</button>
      </div>
    </div>
    <p class="online-room__error" data-online-entry-error hidden role="alert"></p>
  </div>

  <div class="online-room__panel" data-online-view="activeRoom" hidden>
    <h2 class="online-room__title">Sala activa</h2>
    <p class="online-room__code" data-active-room-code>—</p>
    <p class="online-room__status" data-active-room-status>—</p>
    <p class="online-room__muted" data-active-room-meta></p>
    <div class="online-room__cta">
      <button type="button" class="btn" data-online-resume>Reanudar sala</button>
      <button type="button" class="btn-outline" data-online-abandon>Abandonar sala</button>
    </div>
  </div>

  <div class="online-room__panel" data-online-view="roomLobby" hidden>
    <header class="online-room__lobby-head">
      <div>
        <p class="online-room__code-label">Código de sala</p>
        <p class="online-room__code" data-online-room-code>—</p>
        <button type="button" class="btn-outline online-room__copy" data-online-copy-code>Copiar</button>
      </div>
      <div class="online-room__lobby-meta">
        <p class="online-room__status" data-online-status>—</p>
        <p class="online-room__presence" data-online-presence>—</p>
        <p class="online-room__format-pill">11v11 Online</p>
      </div>
      <button type="button" class="btn-outline" data-online-leave>Abandonar</button>
    </header>

    <div class="online-room__players" data-online-players>
      <article class="online-room__player-card" data-online-slot="home">
        <p class="online-room__slot">Local</p>
        <p class="online-room__player-name" data-slot-name>—</p>
        <p data-slot-team>—</p>
        <p data-slot-formation>Alineación personalizada</p>
        <p data-slot-ready>—</p>
        <p data-slot-conn></p>
      </article>
      <article class="online-room__player-card" data-online-slot="away">
        <p class="online-room__slot">Visitante</p>
        <p class="online-room__player-name" data-slot-name>Esperando…</p>
        <p data-slot-team>—</p>
        <p data-slot-formation>—</p>
        <p data-slot-ready>—</p>
        <p data-slot-conn></p>
      </article>
    </div>

    <div class="online-room__lobby-grid">
      <div class="online-room__config">
        <h3>Tu configuración</h3>
        <p class="online-room__section-label">Selección</p>
        <div class="online-room__teams" data-online-team-selector>
          {
            teams.map((team) => (
              <button type="button" class="online-room__team-btn" data-online-team={team.id} title={team.name}>
                <span class="online-room__team-code">{team.code}</span>
                <span class="online-room__team-name">{team.name}</span>
              </button>
            ))
          }
        </div>
        <p class="online-room__section-label">Alineación 11v11</p>
        <div class="online-room__lineup" data-online-lineup-editor></div>
        <div class="online-room__actions">
          <button type="button" class="btn" data-online-ready>Listo</button>
          <button type="button" class="btn-outline" data-online-start hidden>Iniciar cuenta regresiva</button>
        </div>
        <p class="online-room__hint" data-online-hint></p>
        <p class="online-room__error" data-online-lobby-error hidden role="alert"></p>
        <p class="online-room__countdown" data-online-countdown hidden></p>
      </div>

      <div class="online-room__chat">
        <h3>Chat de sala</h3>
        <ul class="online-room__chat-list" data-online-chat-list>
          <li class="online-room__chat-empty" data-online-chat-empty>Aún no hay mensajes.</li>
        </ul>
        <form class="online-room__chat-form" data-online-chat-form>
          <input type="text" maxlength="200" data-online-chat-input placeholder="Escribe un mensaje…" autocomplete="off" />
          <button type="submit" class="btn">Enviar</button>
        </form>
        <p class="online-room__error" data-online-chat-error hidden role="alert"></p>
      </div>
    </div>
  </div>

  <div class="online-room__panel" data-online-view="creatingRoom" hidden>
    <p class="online-room__muted" aria-live="polite">Creando sala…</p>
  </div>
  <div class="online-room__panel" data-online-view="joiningRoom" hidden>
    <p class="online-room__muted" aria-live="polite">Entrando a la sala…</p>
  </div>
  <div class="online-room__panel" data-online-view="connectingMatch" hidden>
    <p class="online-room__muted" aria-live="polite">Conectando al partido…</p>
  </div>
</section>

<style>
  .online-room { margin: 1.25rem 0 2rem; min-height: 14rem; }
  .online-room__title { margin: 0 0 0.5rem; font-family: var(--font-display); font-size: clamp(1.6rem, 3vw, 2.1rem); color: var(--accent); letter-spacing: 0.04em; }
  .online-room__lead, .online-room__muted, .online-room__hint { margin: 0 0 1rem; color: var(--text-muted); line-height: 1.45; }
  .online-room__cta { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .online-room__entry-grid { display: grid; gap: 1rem; }
  @media (min-width: 720px) { .online-room__entry-grid { grid-template-columns: 1fr 1fr; } }
  .online-room__card {
    padding: 1.15rem 1.2rem;
    background: linear-gradient(160deg, color-mix(in srgb, var(--bg-elevated) 88%, var(--accent) 12%), var(--bg-elevated));
    border: 1px solid color-mix(in srgb, var(--border) 70%, var(--accent) 30%);
  }
  .online-room__card h3 { margin: 0 0 0.75rem; font-family: var(--font-display); color: var(--accent); }
  .online-room__field { display: grid; gap: 0.35rem; margin-bottom: 0.75rem; font-size: 0.85rem; }
  .online-room__field input, .online-room__field select, .online-room__chat-form input {
    padding: 0.6rem 0.75rem; border: 1px solid var(--border); background: var(--bg); color: var(--text); font: inherit; width: 100%;
  }
  .online-room__code { margin: 0.15rem 0; font-family: var(--font-display); font-size: 1.85rem; letter-spacing: 0.18em; color: var(--accent); }
  .online-room__code-label { margin: 0; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); }
  .online-room__lobby-head { display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; justify-content: space-between; margin-bottom: 1.15rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border); }
  .online-room__lobby-meta { display: grid; gap: 0.2rem; }
  .online-room__format-pill { margin: 0; font-size: 0.75rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent); }
  .online-room__players { display: grid; gap: 0.75rem; margin-bottom: 1.25rem; }
  @media (min-width: 720px) { .online-room__players { grid-template-columns: 1fr 1fr; } }
  .online-room__player-card {
    padding: 1.05rem 1.1rem;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    min-height: 8.5rem;
  }
  .online-room__player-card--self { border-color: color-mix(in srgb, var(--accent) 55%, var(--border)); box-shadow: inset 3px 0 0 var(--accent); }
  .online-room__player-card--ready { border-color: var(--accent); }
  .online-room__slot { margin: 0 0 0.35rem; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); }
  .online-room__player-name { margin: 0 0 0.35rem; font-family: var(--font-display); font-size: 1.2rem; color: var(--text); }
  .online-room__lobby-grid { display: grid; gap: 1.25rem; align-items: start; }
  @media (min-width: 900px) {
    .online-room__lobby-grid { grid-template-columns: minmax(0, 1.35fr) minmax(16rem, 0.9fr); }
    .online-room__chat { position: sticky; top: 1rem; }
  }
  .online-room__section-label { margin: 0.85rem 0 0.45rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.07em; color: var(--text-muted); }
  .online-room__teams { display: grid; grid-template-columns: repeat(auto-fill, minmax(7.5rem, 1fr)); gap: 0.45rem; margin-bottom: 0.5rem; }
  .online-room__team-btn {
    display: grid; gap: 0.15rem; padding: 0.55rem 0.6rem; border: 1px solid var(--border);
    background: transparent; color: var(--text); cursor: pointer; font: inherit; text-align: left;
  }
  .online-room__team-code { font-family: var(--font-display); color: var(--accent); font-size: 0.95rem; }
  .online-room__team-name { font-size: 0.75rem; color: var(--text-muted); line-height: 1.2; }
  .online-room__team-btn--active { border-color: var(--accent); background: color-mix(in srgb, var(--bg-elevated) 70%, var(--accent) 12%); }
  .online-room__team-btn:disabled { opacity: 0.35; cursor: not-allowed; }
  .online-room__actions { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 0.85rem 0 0.5rem; }
  .online-room__error { margin: 0.5rem 0 0; color: #ff7b7b; font-size: 0.9rem; }
  .online-room__countdown { margin: 0.75rem 0 0; font-family: var(--font-display); color: var(--accent); }
  .online-room__chat {
    padding: 1rem;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
  }
  .online-room__chat h3 { margin: 0 0 0.65rem; font-family: var(--font-display); color: var(--accent); font-size: 1.1rem; }
  .online-room__chat-list {
    list-style: none; margin: 0 0 0.75rem; padding: 0.75rem; min-height: 10rem; max-height: 16rem; overflow: auto;
    background: var(--bg); border: 1px solid var(--border);
  }
  .online-room__chat-form { display: grid; grid-template-columns: 1fr auto; gap: 0.5rem; }
  .online-room__skel-line { height: 0.85rem; margin-bottom: 0.5rem; background: var(--bg-elevated); border-radius: 4px; }
  .online-room__skel-line--short { width: 40%; }
  .online-room__copy { margin-top: 0.35rem; }
  @media (max-width: 640px) {
    .online-room__cta .btn, .online-room__cta .btn-outline, .online-room__card .btn, .online-room__actions .btn, .online-room__actions .btn-outline { width: 100%; }
  }
</style>

<script>
  import {
    awaitAuthReady,
    ensureAccessToken,
    getAuthState,
    hydrateSession,
    refreshSessionOnce,
    setSignOutCleanup,
    subscribeAuth,
  } from '../lib/auth/session';
  import { getSelectedTeam } from '../lib/storage/selectedTeam';
  import { DEFAULT_FORMATION, type FormationId, isFormationId } from '../lib/match/formations';
  import { cloneDefaultLineup, chatMessageDedupeKey, normalizeLineup, type CustomLineup } from '../lib/match/lineup';
  import { mountLineupEditor, type LineupEditorHandle } from '../lib/match/lineupEditor';
  import {
    createPrivateRoom,
    joinPrivateRoom,
    leavePrivateRoom,
    leaveActivePrivateRoom,
    recoverActivePrivateRoom,
    updateRoomLoadout,
    setRoomReady,
    startPrivateRoom,
    sendRoomChat,
    touchRoomPresence,
  } from '../lib/match/privateRoomApi';
  import { roomStatusLabel, type RoomSnapshot, type RoomChatMessage } from '../lib/match/roomTypes';
  import { deriveOnlineUiState, needsAbandonConfirm, type OnlineUiState } from '../lib/match/onlineUiState';
  import { CHANNELS } from '../lib/realtime/channels';
  import {
    subscribe,
    onEvent,
    onPresenceJoin,
    onPresenceLeave,
    isRealtimeAvailable,
    cleanup as cleanupRealtime,
  } from '../lib/realtime/client';

  function wireOnlineRoom() {
    const root = document.querySelector<HTMLElement>('[data-online-room]');
    if (!root || root.dataset.wired === '1') return;
    root.dataset.wired = '1';

    const teams = JSON.parse(root.dataset.teams ?? '[]') as Array<{ id: string; name: string; code: string }>;
    const views = Array.from(root.querySelectorAll<HTMLElement>('[data-online-view]'));

    let room: RoomSnapshot | null = null;
    let pendingActive: RoomSnapshot | null = null;
    let inLobby = false;
    let checkingActive = false;
    let busyAction: 'create' | 'join' | null = null;
    let matchConnecting = false;
    let matchActive = false;
    let errorKind: 'recoverable' | 'fatal' | null = null;
    let errorMsg = '';
    let myFormation: FormationId = DEFAULT_FORMATION;
    let myTeamId = getSelectedTeam() || teams[0]?.id || 'brasil';
    let myLineup: CustomLineup = cloneDefaultLineup();
    let lineupEditor: LineupEditorHandle | null = null;
    let presenceIds = new Set<string>();
    let roomUnsubs: Array<() => void> = [];
    let touchTimer: number | null = null;
    let countdownTimer: number | null = null;
    let uiState: OnlineUiState = 'hydratingSession';
    const seenChatKeys = new Set<string>();

    function ensureLineupEditor() {
      const root = document.querySelector<HTMLElement>('[data-online-lineup-editor]');
      if (!root) return;
      if (!lineupEditor) {
        lineupEditor = mountLineupEditor(root, {
          initial: myLineup,
          onChange: (next) => {
            myLineup = next;
            void persistLineup();
          },
        });
      } else {
        lineupEditor.setLineup(myLineup);
      }
    }

    async function persistLineup() {
      if (!room) return;
      const result = await updateRoomLoadout({ roomId: room.id, lineup: myLineup });
      if (result.ok) room = result.data.room;
    }

    function teamName(id: string | null) {
      if (!id) return 'Sin selección';
      return teams.find((t) => t.id === id)?.name ?? id;
    }

    function setError(el: HTMLElement | null, message: string | null) {
      if (!el) return;
      el.hidden = !message;
      el.textContent = message ?? '';
    }

    function showView(state: OnlineUiState) {
      uiState = state;
      for (const view of views) {
        view.hidden = view.dataset.onlineView !== state;
      }
      window.dispatchEvent(
        new CustomEvent('golazo:online-ui-state', {
          detail: { state, hasActiveRoom: Boolean(pendingActive || (room && !inLobby)) },
        }),
      );
    }

    function renderUi() {
      const auth = getAuthState();
      const hasToken = Boolean(auth.accessToken);
      const next = deriveOnlineUiState({
        sessionPhase: auth.phase,
        hasToken,
        checkingActive,
        room: inLobby ? room : pendingActive,
        inLobby,
        busyAction,
        matchConnecting,
        matchActive,
        errorKind: errorKind ?? (auth.phase === 'expired' || (auth.user && !hasToken && auth.sessionReady) ? 'recoverable' : null),
      });

      if (next === 'recoverableError') {
        const msgEl = root.querySelector<HTMLElement>('[data-online-error-msg]');
        if (msgEl) {
          msgEl.textContent =
            errorMsg || auth.tokenError || 'La sesión expiró. Vuelve a iniciar sesión.';
        }
      }

      if (next === 'activeRoom' && pendingActive) {
        const codeEl = root.querySelector('[data-active-room-code]');
        const statusEl = root.querySelector('[data-active-room-status]');
        const metaEl = root.querySelector('[data-active-room-meta]');
        if (codeEl) codeEl.textContent = pendingActive.code;
        if (statusEl) statusEl.textContent = roomStatusLabel(pendingActive.status);
        if (metaEl) {
          metaEl.textContent = pendingActive.players
            .map((p) => teamName(p.teamId))
            .join(' · ');
        }
      }

      showView(next);
    }

    function clearRoomRealtime() {
      for (const unsub of roomUnsubs.splice(0)) unsub();
      if (touchTimer) {
        window.clearInterval(touchTimer);
        touchTimer = null;
      }
      if (countdownTimer) {
        window.clearInterval(countdownTimer);
        countdownTimer = null;
      }
    }

    function resetOnlineLocal() {
      clearRoomRealtime();
      room = null;
      pendingActive = null;
      inLobby = false;
      matchConnecting = false;
      matchActive = false;
      busyAction = null;
      presenceIds.clear();
      const chatList = root.querySelector('[data-online-chat-list]');
      chatList?.querySelectorAll('li:not([data-online-chat-empty])').forEach((n) => n.remove());
      const chatEmpty = root.querySelector<HTMLElement>('[data-online-chat-empty]');
      if (chatEmpty) chatEmpty.hidden = false;
      const countdownEl = root.querySelector<HTMLElement>('[data-online-countdown]');
      if (countdownEl) countdownEl.hidden = true;
    }

    setSignOutCleanup(() => {
      resetOnlineLocal();
      try {
        cleanupRealtime();
      } catch {
        // ignore
      }
    });

    function renderSlots() {
      if (!room) return;
      const me = getAuthState().user?.id;
      for (const slot of ['home', 'away'] as const) {
        const card = root.querySelector(`[data-online-slot="${slot}"]`);
        if (!card) continue;
        const player = room.players.find((p) => p.slot === slot);
        const nameEl = card.querySelector('[data-slot-name]');
        const teamEl = card.querySelector('[data-slot-team]');
        const formationEl = card.querySelector('[data-slot-formation]');
        const readyEl = card.querySelector('[data-slot-ready]');
        const connEl = card.querySelector('[data-slot-conn]');
        card.classList.toggle('online-room__player-card--self', Boolean(player && player.userId === me));
        card.classList.toggle('online-room__player-card--ready', Boolean(player?.ready));
        if (!player) {
          if (nameEl) nameEl.textContent = slot === 'away' ? 'Esperando…' : '—';
          if (teamEl) teamEl.textContent = '—';
          if (formationEl) formationEl.textContent = '—';
          if (readyEl) readyEl.textContent = '—';
          if (connEl) connEl.textContent = '';
          continue;
        }
        const label = player.displayName || player.username || player.userId.slice(0, 8);
        if (nameEl) nameEl.textContent = player.userId === me ? `${label} (tú)` : label;
        if (teamEl) teamEl.textContent = teamName(player.teamId);
        if (formationEl) formationEl.textContent = player.lineup?.length ? 'Alineación lista' : 'Sin alineación';
        if (readyEl) readyEl.textContent = player.ready ? 'Listo' : 'No listo';
        if (connEl) connEl.textContent = presenceIds.has(player.userId) ? 'Conectado' : 'Desconectado';
      }
    }

    function renderConfig() {
      if (!room) return;
      const me = getAuthState().user?.id;
      const mine = room.players.find((p) => p.userId === me);
      if (mine?.teamId) myTeamId = mine.teamId;
      if (mine?.formationId && isFormationId(mine.formationId)) myFormation = mine.formationId;
      if (mine?.lineup) {
        const normalized = normalizeLineup(mine.lineup);
        if (normalized) myLineup = normalized;
      }
      ensureLineupEditor();
      const taken = new Set(
        room.players.filter((p) => p.userId !== me && p.teamId).map((p) => p.teamId as string),
      );
      for (const btn of root.querySelectorAll<HTMLButtonElement>('[data-online-team]')) {
        const id = btn.dataset.onlineTeam ?? '';
        btn.classList.toggle('online-room__team-btn--active', id === myTeamId);
        btn.disabled = taken.has(id);
      }
      const readyBtn = root.querySelector<HTMLButtonElement>('[data-online-ready]');
      const startBtn = root.querySelector<HTMLButtonElement>('[data-online-start]');
      const statusEl = root.querySelector('[data-online-status]');
      const presenceEl = root.querySelector('[data-online-presence]');
      if (readyBtn) {
        readyBtn.textContent = mine?.ready ? 'Cancelar listo' : 'Listo';
        readyBtn.disabled = room.status === 'starting' || room.status === 'playing';
      }
      if (startBtn) {
        startBtn.hidden = !(room.hostUserId === me && room.status === 'ready');
      }
      if (statusEl) statusEl.textContent = roomStatusLabel(room.status);
      if (presenceEl) presenceEl.textContent = `Presencia: ${presenceIds.size}/${room.players.length}`;
      const codeEl = root.querySelector('[data-online-room-code]');
      if (codeEl) codeEl.textContent = room.code;
    }

    async function bindRoomRealtime(roomId: string) {
      clearRoomRealtime();
      if (!isRealtimeAvailable()) return;
      const channel = CHANNELS.room(roomId);
      const sub = await subscribe(channel);
      presenceIds = new Set(
        (sub.members ?? []).filter((m) => m.type === 'user').map((m) => m.presenceId),
      );
      roomUnsubs.push(
        onEvent('room_updated', (payload) => {
          if (!payload || payload.id !== roomId) return;
          room = payload as unknown as RoomSnapshot;
          renderSlots();
          renderConfig();
        }),
      );
      roomUnsubs.push(
        onEvent('room_starting', (payload) => {
          if (!payload || payload.roomId !== roomId) return;
          const countdownEl = root.querySelector<HTMLElement>('[data-online-countdown]');
          if (!countdownEl) return;
          countdownEl.hidden = false;
          let left = Number(payload.countdownSeconds ?? 5);
          countdownEl.textContent = `El partido comienza en… ${left}`;
          if (countdownTimer) window.clearInterval(countdownTimer);
          countdownTimer = window.setInterval(() => {
            left -= 1;
            if (left <= 0) {
              countdownEl.textContent = 'Conectando…';
              if (countdownTimer) window.clearInterval(countdownTimer);
              countdownTimer = null;
              matchConnecting = true;
              renderUi();
              const me = getAuthState().user?.id;
              const mine = room?.players.find((p) => p.userId === me);
              window.dispatchEvent(
                new CustomEvent('golazo:online-match-start', {
                  detail: {
                    roomId,
                    playerSide: mine?.slot === 'away' ? 'away' : 'home',
                    homeTeamId: room?.players.find((p) => p.slot === 'home')?.teamId,
                    awayTeamId: room?.players.find((p) => p.slot === 'away')?.teamId,
                    homeFormationId: room?.players.find((p) => p.slot === 'home')?.formationId,
                    awayFormationId: room?.players.find((p) => p.slot === 'away')?.formationId,
                    homeLineup: room?.players.find((p) => p.slot === 'home')?.lineup ?? cloneDefaultLineup(),
                    awayLineup: room?.players.find((p) => p.slot === 'away')?.lineup ?? cloneDefaultLineup(),
                    durationSeconds: room?.durationSeconds ?? 180,
                    formatId: '11v11',
                  },
                }),
              );
              return;
            }
            countdownEl.textContent = `El partido comienza en… ${left}`;
          }, 1000);
        }),
      );
      roomUnsubs.push(
        onEvent('room_chat_message', (payload) => {
          if (!payload || payload.roomId !== roomId) return;
          appendChat(payload as unknown as RoomChatMessage);
        }),
      );
      roomUnsubs.push(
        onPresenceJoin(({ member, meta }) => {
          if (meta.channel !== channel) return;
          if (member.type === 'user') presenceIds.add(member.presenceId);
          renderSlots();
          renderConfig();
        }),
      );
      roomUnsubs.push(
        onPresenceLeave(({ member, meta }) => {
          if (meta.channel !== channel) return;
          presenceIds.delete(member.presenceId);
          renderSlots();
          renderConfig();
        }),
      );
      touchTimer = window.setInterval(() => {
        void touchRoomPresence(roomId);
      }, 60_000);
    }

    function appendChat(msg: RoomChatMessage) {
      const key = chatMessageDedupeKey(msg);
      if (seenChatKeys.has(key)) return;
      seenChatKeys.add(key);
      const chatList = root.querySelector('[data-online-chat-list]');
      const chatEmpty = root.querySelector<HTMLElement>('[data-online-chat-empty]');
      if (!chatList) return;
      if (chatEmpty) chatEmpty.hidden = true;
      const li = document.createElement('li');
      const who = room?.players.find((p) => p.userId === msg.userId);
      const label = who?.displayName || who?.username || msg.userId.slice(0, 8);
      const meta = document.createElement('span');
      meta.style.color = 'var(--accent)';
      meta.style.fontWeight = '600';
      meta.textContent = `${label}: `;
      li.append(meta, document.createTextNode(msg.body));
      chatList.appendChild(li);
      chatList.scrollTop = chatList.scrollHeight;
    }

    async function enterLobby(next: RoomSnapshot) {
      room = next;
      pendingActive = null;
      inLobby = true;
      errorKind = null;
      errorMsg = '';
      busyAction = null;
      seenChatKeys.clear();
      const me = getAuthState().user?.id;
      const mine = next.players.find((p) => p.userId === me);
      if (mine?.lineup) {
        const normalized = normalizeLineup(mine.lineup);
        if (normalized) myLineup = normalized;
      }
      await bindRoomRealtime(next.id);
      ensureLineupEditor();
      renderSlots();
      renderConfig();
      renderUi();
    }

    async function checkActiveRoom() {
      const auth = getAuthState();
      if (!auth.user || !auth.accessToken) {
        checkingActive = false;
        renderUi();
        return;
      }
      checkingActive = true;
      renderUi();
      const result = await recoverActivePrivateRoom();
      checkingActive = false;
      if (result.ok && result.data.room) {
        pendingActive = result.data.room;
        inLobby = false;
        room = null;
      } else {
        pendingActive = null;
      }
      renderUi();
    }

    async function syncSessionGate() {
      await awaitAuthReady();
      await ensureAccessToken();
      const auth = getAuthState();
      if (auth.user && auth.accessToken) {
        errorKind = null;
        await checkActiveRoom();
      } else {
        pendingActive = null;
        renderUi();
      }
    }

    root.querySelector('[data-online-create]')?.addEventListener('click', async () => {
      if (busyAction) return;
      busyAction = 'create';
      setError(root.querySelector('[data-online-entry-error]'), null);
      renderUi();
      const durationSelect = root.querySelector<HTMLSelectElement>('[data-online-duration]');
      const result = await createPrivateRoom({
        teamId: myTeamId,
        formationId: myFormation,
        durationSeconds: Number(durationSelect?.value ?? 180),
        lineup: myLineup,
      });
      busyAction = null;
      if (!result.ok) {
        if (result.error.code === 'ALREADY_IN_ROOM') {
          await checkActiveRoom();
          return;
        }
        setError(root.querySelector('[data-online-entry-error]'), result.error.message);
        renderUi();
        return;
      }
      await enterLobby(result.data.room);
    });

    root.querySelector('[data-online-join]')?.addEventListener('click', async () => {
      if (busyAction) return;
      busyAction = 'join';
      setError(root.querySelector('[data-online-entry-error]'), null);
      renderUi();
      const codeInput = root.querySelector<HTMLInputElement>('[data-online-code]');
      const code = (codeInput?.value ?? '').trim().toUpperCase();
      if (codeInput) codeInput.value = code;
      const result = await joinPrivateRoom({ code, teamId: myTeamId, formationId: myFormation, lineup: myLineup });
      busyAction = null;
      if (!result.ok) {
        if (result.error.code === 'ALREADY_IN_ROOM') {
          await checkActiveRoom();
          return;
        }
        setError(root.querySelector('[data-online-entry-error]'), result.error.message);
        renderUi();
        return;
      }
      await enterLobby(result.data.room);
    });

    root.querySelector('[data-online-resume]')?.addEventListener('click', async () => {
      if (!pendingActive) return;
      await enterLobby(pendingActive);
    });

    async function abandonFlow(fromLobby: boolean) {
      const target = fromLobby ? room : pendingActive;
      if (!target) return;
      if (needsAbandonConfirm(target.status)) {
        const ok = window.confirm('¿Abandonar el partido en curso?');
        if (!ok) return;
      }
      if (fromLobby && room) {
        await leavePrivateRoom(room.id);
      } else {
        await leaveActivePrivateRoom();
      }
      resetOnlineLocal();
      renderUi();
    }

    root.querySelector('[data-online-abandon]')?.addEventListener('click', () => {
      void abandonFlow(false);
    });
    root.querySelector('[data-online-leave]')?.addEventListener('click', () => {
      void abandonFlow(true);
    });

    root.querySelector('[data-online-retry-session]')?.addEventListener('click', async () => {
      errorKind = null;
      errorMsg = '';
      await refreshSessionOnce();
      await syncSessionGate();
    });

    root.querySelector('[data-online-copy-code]')?.addEventListener('click', async () => {
      if (!room?.code) return;
      try {
        await navigator.clipboard.writeText(room.code);
      } catch {
        // ignore
      }
    });

    for (const btn of root.querySelectorAll<HTMLButtonElement>('[data-online-team]')) {
      btn.addEventListener('click', async () => {
        if (!room || btn.disabled) return;
        const teamId = btn.dataset.onlineTeam;
        if (!teamId) return;
        const result = await updateRoomLoadout({ roomId: room.id, teamId, lineup: myLineup });
        if (!result.ok) {
          setError(root.querySelector('[data-online-lobby-error]'), result.error.message);
          return;
        }
        myTeamId = teamId;
        room = result.data.room;
        renderSlots();
        renderConfig();
      });
    }

    root.querySelector('[data-online-ready]')?.addEventListener('click', async () => {
      if (!room) return;
      const me = getAuthState().user?.id;
      const mine = room.players.find((p) => p.userId === me);
      const result = await setRoomReady(room.id, !mine?.ready);
      if (!result.ok) {
        setError(root.querySelector('[data-online-lobby-error]'), result.error.message);
        return;
      }
      room = result.data.room;
      renderSlots();
      renderConfig();
    });

    root.querySelector('[data-online-start]')?.addEventListener('click', async () => {
      if (!room) return;
      const result = await startPrivateRoom(room.id);
      if (!result.ok) {
        setError(root.querySelector('[data-online-lobby-error]'), result.error.message);
        return;
      }
      room = result.data.room;
      renderConfig();
    });

    root.querySelector('[data-online-chat-form]')?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!room) return;
      const input = root.querySelector<HTMLInputElement>('[data-online-chat-input]');
      const message = input?.value ?? '';
      setError(root.querySelector('[data-online-chat-error]'), null);
      const result = await sendRoomChat(room.id, message);
      if (!result.ok) {
        setError(root.querySelector('[data-online-chat-error]'), result.error.message);
        return;
      }
      if (input) input.value = '';
      if (result.data.message) appendChat(result.data.message);
    });

    window.addEventListener('golazo:play-mode', ((event: CustomEvent<{ mode: string }>) => {
      const mode = event.detail?.mode;
      root.hidden = mode !== 'online';
      if (mode === 'online') {
        void syncSessionGate();
      }
    }) as EventListener);

    window.addEventListener('golazo:team-selected', ((event: CustomEvent<{ teamId: string }>) => {
      if (event.detail?.teamId) myTeamId = event.detail.teamId;
    }) as EventListener);

    window.addEventListener('golazo:online-conn', ((event: CustomEvent<{ status: string }>) => {
      if (event.detail?.status === 'connected') {
        matchConnecting = false;
        matchActive = true;
        renderUi();
      }
    }) as EventListener);

    subscribeAuth(() => {
      if (!root.hidden) renderUi();
    });

    void hydrateSession().then(() => {
      if (!root.hidden) void syncSessionGate();
      else renderUi();
    });
  }

  wireOnlineRoom();
</script>
