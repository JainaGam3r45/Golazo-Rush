---
import Layout from '../layouts/Layout.astro';
import LiveStats from '../components/LiveStats.astro';
import ActivityFeed from '../components/ActivityFeed.astro';
import LobbyPanel from '../components/LobbyPanel.astro';
import TeamCard from '../components/TeamCard.astro';
import { getHomeStats } from '../lib/data/stats';
import { getTopRankings } from '../lib/data/rankings';
import { getTeams } from '../lib/data/teams';

const [homeStats, topTeams, teams] = await Promise.all([
  getHomeStats(),
  getTopRankings(5),
  getTeams(),
]);
const teamMap = Object.fromEntries(teams.map((team) => [team.id, team]));
const teamNames = Object.fromEntries(teams.map((team) => [team.id, team.name]));
---

<Layout title="Golazo Rush — Inicio">
  <section class="hero">
    <h1 class="hero__title">Golazo Rush</h1>
    <p class="hero__tagline">Fútbol arcade de ritmo rápido. Marca goles y escala el ranking mundial.</p>
    <a href="/play" class="btn">Jugar ahora</a>
  </section>

  <section class="section">
    <h2 class="section-title">Estadísticas en vivo</h2>
    <LiveStats stats={homeStats} />
  </section>

  <section class="section grid-two">
    <div>
      <h2 class="section-title">Mejores selecciones</h2>
      <div class="ranking-preview">
        {topTeams.length === 0 ? (
          <p class="ranking-preview__empty">Sin partidos todavía. ¡Juega el primero!</p>
        ) : (
          topTeams.map((ranking) => (
            <TeamCard ranking={ranking} team={teamMap[ranking.teamId]} compact />
          ))
        )}
      </div>
      <a href="/ranking" class="link-more">Ver ranking completo →</a>
    </div>
    <div>
      <h2 class="section-title">Actividad reciente</h2>
      <ActivityFeed />
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Lobby</h2>
    <LobbyPanel />
  </section>
</Layout>

<script define:vars={{ teamNames }}>
  import { CHANNELS } from '../lib/realtime/channels';
  import {
    subscribe,
    onEvent,
    onPresenceJoin,
    onPresenceLeave,
    isRealtimeAvailable,
  } from '../lib/realtime/client';
  import { formatOnlineCount } from '../lib/realtime/presence';
  import {
    appendLobbyMatch,
    removeLobbyMatch,
    renderLobbyPresence,
    setTeamNames,
  } from '../lib/realtime/handlers';

  async function wireHomeRealtime() {
    if (!isRealtimeAvailable()) return;

    setTeamNames(teamNames);

    const presenceResult = await subscribe(CHANNELS.PRESENCE);
    if (presenceResult.ok) {
      let members = presenceResult.members.map((m) => ({
        presenceId: m.presenceId,
        type: m.type as 'user' | 'anonymous',
        joinedAt: m.joinedAt,
      }));

      const onlineEl = document.querySelector('[data-stat-live="online"] [data-stat-value]');
      if (onlineEl) {
        onlineEl.textContent = formatOnlineCount(members.length);
      }

      const lobbyResult = await subscribe(CHANNELS.LOBBY);
      if (lobbyResult.ok) {
        let lobbyMembers = lobbyResult.members.map((m) => ({ presenceId: m.presenceId }));
        renderLobbyPresence(lobbyMembers, '[data-lobby-presence]');
        document.querySelector('[data-lobby-empty]')?.remove();

        onPresenceJoin(({ member, meta }) => {
          if (meta.channel === CHANNELS.PRESENCE) {
            const exists = members.some((m) => m.presenceId === member.presenceId);
            members = exists ? members : [...members, member as typeof members[0]];
            if (onlineEl) onlineEl.textContent = formatOnlineCount(members.length);
          }
          if (meta.channel === CHANNELS.LOBBY) {
            if (lobbyMembers.some((m) => m.presenceId === member.presenceId)) return;
            lobbyMembers = [...lobbyMembers, { presenceId: member.presenceId }];
            renderLobbyPresence(lobbyMembers, '[data-lobby-presence]');
          }
        });

        onPresenceLeave(({ member, meta }) => {
          if (meta.channel === CHANNELS.PRESENCE) {
            members = members.filter((m) => m.presenceId !== member.presenceId);
            if (onlineEl) onlineEl.textContent = formatOnlineCount(members.length);
          }
          if (meta.channel === CHANNELS.LOBBY) {
            lobbyMembers = lobbyMembers.filter((m) => m.presenceId !== member.presenceId);
            renderLobbyPresence(lobbyMembers, '[data-lobby-presence]');
          }
        });

        onEvent('match_created', (payload) => {
          document.querySelector('[data-lobby-empty]')?.remove();
          appendLobbyMatch(payload, '[data-lobby-matches]');
        });

        onEvent('match_finished', (payload) => {
          removeLobbyMatch(String(payload.matchId), '[data-lobby-matches]');
        });
      }
    }
  }

  wireHomeRealtime();
</script>
