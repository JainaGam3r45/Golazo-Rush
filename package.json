{
  "name": "golazo-rush",
  "type": "module",
  "version": "0.5.0",
  "author": {
    "name": "JainaGam3r45",
    "url": "https://github.com/JainaGam3r45"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm generate:flags && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate:flags": "node scripts/generate-flag-sprite.mjs",
    "test:unit": "node --experimental-strip-types --test tests/unit/roomRules.test.ts tests/unit/onlineClient.test.ts tests/unit/onlineAuth.test.ts tests/unit/privateRoomApi.test.ts",
    "test:game-sim": "pnpm --filter @golazo-rush/game-sim test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:mp": "node --test tests/multiplayer/**/*.test.mjs",
    "mp:acceptance": "node tools/mp-acceptance/run.mjs"
  },
  "dependencies": {
    "@insforge/sdk": "^1.4.3",
    "astro": "^7.0.7",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "flag-icons": "^7.5.0",
    "svgo": "^3.3.2"
  }
}
