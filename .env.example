# Variables públicas del cliente (Astro)
# Obtén la anon key con: npx @insforge/cli secrets get ANON_KEY
PUBLIC_INSFORGE_BASE_URL=
PUBLIC_INSFORGE_ANON_KEY=

# Game server (HTTP + WSS). Same host for /health, POST /room, and WebSocket.
# Example: https://golazo-game.up.railway.app or http://127.0.0.1:8787
# When set, privateRoomApi uses POST ${PUBLIC_GAME_SERVER_URL}/room (Bearer token)
# for all private-room actions instead of InsForge functions.invoke('private-room').
# Client diagnostic (unlisted): /dev/ws-probe
PUBLIC_GAME_SERVER_URL=

# Edge functions (solo servidor — configurar con npx @insforge/cli secrets set)
# INSFORGE_BASE_URL=
# ANON_KEY=
# INSFORGE_API_KEY=
# ROOM_CLEANUP_SECRET=

# --- services/game-server (Railway / local; never expose API key to browser) ---
# PORT=
# ALLOWED_ORIGINS=https://your-app.example,http://localhost:4321
# PUBLIC_APP_ORIGIN=https://your-app.example
# INSFORGE_BASE_URL=https://b963cy5n.us-east.insforge.app
# INSFORGE_API_KEY=
# WS_AUTH_MODE=insforge
# WS_TEST_TOKEN=
# LOG_LEVEL=info
# NODE_ENV=production
