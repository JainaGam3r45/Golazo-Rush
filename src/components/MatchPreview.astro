---
import CountryFlag from './CountryFlag.astro';
import type { Team } from '../lib/mock/teams';
import { ALLOWED_DURATIONS, DEFAULT_DURATION } from '../lib/match/setup';

interface Props {
  teams: Team[];
}

const { teams } = Astro.props;
---

<section class="match-preview" data-match-preview hidden data-teams={JSON.stringify(teams)}>
  <h2 class="match-preview__title">Previa del partido</h2>
  <p class="match-preview__mode-badge" data-preview-mode-badge>11v11 Contra bots</p>

  <div class="match-preview__teams">
    <div class="match-preview__team" data-preview-home>
      <CountryFlag teamId="brasil" team={teams.find((t) => t.id === 'brasil')} size="lg" />
      <span class="match-preview__team-name" data-preview-home-name>—</span>
      <span class="match-preview__side">Local</span>
    </div>

    <span class="match-preview__vs">VS</span>

    <div class="match-preview__team" data-preview-away>
      <CountryFlag teamId="argentina" team={teams.find((t) => t.id === 'argentina')} size="lg" />
      <span class="match-preview__team-name" data-preview-away-name>—</span>
      <span class="match-preview__side">Visitante</span>
    </div>
  </div>

  <div class="match-preview__format" data-format-block>
    <span class="match-preview__format-label">Formato</span>
    <p class="match-preview__format-fixed">11v11 completo · 1 arquero + 10 de campo</p>
  </div>

  <div class="match-preview__formation" data-formation-block>
    <span class="match-preview__formation-label" data-formation-label>Tu alineación</span>
    <div class="match-preview__lineup" data-lineup-editor></div>
  </div>

  <div class="match-preview__duration">
    <span class="match-preview__duration-label">Duración</span>
    <div class="match-preview__duration-options" role="radiogroup" aria-label="Duración del partido">
      {
        ALLOWED_DURATIONS.map((seconds) => (
          <button
            type="button"
            class="match-preview__duration-btn"
            data-duration={seconds}
            role="radio"
            aria-checked={seconds === DEFAULT_DURATION ? 'true' : 'false'}
          >
            {seconds / 60} min
          </button>
        ))
      }
    </div>
  </div>

  <div class="match-preview__actions">
    <button type="button" class="btn-outline match-preview__change-rival" data-change-rival>
      Cambiar rival
    </button>
    <button type="button" class="btn match-preview__play" data-play-match>
      Jugar
    </button>
  </div>
</section>

<script>
  import {
    buildMatchSetup,
    finalizeMatchSetup,
    pickRandomOpponent,
    validateDuration,
    isValidOpponent,
  } from '../lib/match/setup';
  import { DEFAULT_FORMATION } from '../lib/match/formations';
  import { formatModeLabel } from '../lib/match/formats';
  import { cloneDefaultLineup, type CustomLineup } from '../lib/match/lineup';
  import { mountLineupEditor } from '../lib/match/lineupEditor';
  import { updateCountryFlagElement } from '../lib/teams/flagDom';

  function wireMatchPreview() {
    const section = document.querySelector<HTMLElement>('[data-match-preview]');
    if (!section) return;

    const teams = JSON.parse(section.dataset.teams ?? '[]');
    const homeFlag = section.querySelector('[data-preview-home] .country-flag');
    const awayFlag = section.querySelector('[data-preview-away] .country-flag');
    const homeName = section.querySelector('[data-preview-home-name]');
    const awayName = section.querySelector('[data-preview-away-name]');
    const playBtn = section.querySelector<HTMLButtonElement>('[data-play-match]');
    const changeRivalBtn = section.querySelector('[data-change-rival]');
    const durationBtns = section.querySelectorAll<HTMLButtonElement>('[data-duration]');
    const modeBadge = section.querySelector<HTMLElement>('[data-preview-mode-badge]');
    const lineupRoot = section.querySelector<HTMLElement>('[data-lineup-editor]');

    let playerTeamId = '';
    let opponentTeamId = '';
    let durationSeconds = 900;
    let lineup: CustomLineup = cloneDefaultLineup();

    const editor = lineupRoot
      ? mountLineupEditor(lineupRoot, {
          initial: lineup,
          onChange: (next) => {
            lineup = next;
          },
        })
      : null;

    function getTeam(id: string) {
      return teams.find((t: { id: string }) => t.id === id);
    }

    function updateFlagEl(flagEl: Element | null, team: { id: string; name: string } | undefined) {
      if (!flagEl || !team) return;
      updateCountryFlagElement(flagEl, team.id, team.name);
    }

    function renderPreview() {
      const setup = buildMatchSetup(
        {
          playerTeamId,
          opponentTeamId,
          durationSeconds,
          formationId: DEFAULT_FORMATION,
          formatId: '11v11',
          lineup,
        },
        teams,
      );
      playerTeamId = setup.playerTeamId;
      opponentTeamId = setup.opponentTeamId;

      const homeTeam = getTeam(setup.homeTeamId);
      const awayTeam = getTeam(setup.awayTeamId);

      updateFlagEl(homeFlag, homeTeam);
      updateFlagEl(awayFlag, awayTeam);
      if (homeName) homeName.textContent = homeTeam?.name ?? setup.homeTeamId;
      if (awayName) awayName.textContent = awayTeam?.name ?? setup.awayTeamId;
      if (modeBadge) modeBadge.textContent = formatModeLabel('11v11');

      const valid = isValidOpponent(playerTeamId, opponentTeamId);
      if (playBtn) playBtn.disabled = !valid;
    }

    window.addEventListener('golazo:team-selected', (event) => {
      const detail = (event as CustomEvent).detail;
      playerTeamId = detail.teamId;
      opponentTeamId = pickRandomOpponent(playerTeamId, teams);
      renderPreview();
    });

    changeRivalBtn?.addEventListener('click', () => {
      opponentTeamId = pickRandomOpponent(playerTeamId, teams);
      renderPreview();
    });

    for (const btn of durationBtns) {
      btn.addEventListener('click', () => {
        durationSeconds = validateDuration(Number(btn.dataset.duration));
        for (const b of durationBtns) {
          const active = Number(b.dataset.duration) === durationSeconds;
          b.classList.toggle('match-preview__duration-btn--active', active);
          b.setAttribute('aria-checked', active ? 'true' : 'false');
        }
      });
    }

    const defaultDurationBtn = section.querySelector('[data-duration="900"]');
    defaultDurationBtn?.classList.add('match-preview__duration-btn--active');

    playBtn?.addEventListener('click', () => {
      if (editor) lineup = editor.getLineup();
      const setup = finalizeMatchSetup(
        buildMatchSetup(
          {
            playerTeamId,
            opponentTeamId,
            durationSeconds,
            formationId: DEFAULT_FORMATION,
            formatId: '11v11',
            lineup,
          },
          teams,
        ),
      );
      window.dispatchEvent(new CustomEvent('golazo:start-match', { detail: setup }));
    });

    renderPreview();
  }

  wireMatchPreview();
</script>
