---
import type { Team } from '../lib/mock/teams';
import { getTeamFlagAlt, getTeamFlagSrc } from '../lib/teams/flags';

interface Props {
  teamId: string;
  team?: Team;
  teamName?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { teamId, team, teamName: teamNameProp, size = 'md' } = Astro.props;
const teamName = teamNameProp ?? team?.name;
const flagSrc = getTeamFlagSrc(teamId);
const flagAlt = getTeamFlagAlt(teamId, teamName);
---

<span
  class:list={['country-flag', `country-flag--${size}`]}
  data-team-id={teamId}
>
  <img
    class="country-flag__img"
    src={flagSrc}
    alt={flagAlt}
    width="40"
    height="28"
    loading="lazy"
    decoding="async"
  />
</span>
