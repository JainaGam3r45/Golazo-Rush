# Variables públicas del cliente (Astro)
# Obtén la anon key con: npx @insforge/cli secrets get ANON_KEY
PUBLIC_INSFORGE_BASE_URL=
PUBLIC_INSFORGE_ANON_KEY=

# Optional InsForge Compute / local game-server (HTTP + WSS).
# Private-room lobby actions use authenticated DB RPCs via @insforge/sdk by default.
# When set, POST ${PUBLIC_GAME_SERVER_URL}/room is an optional fallback / WS host.
# Local: http://127.0.0.1:8787
# Production (healthy 2026-07-10): wss://golazo-match-298feacd-4df4-4889-85ac-dd95957fddbf.fly.dev
#   (https://… also works; client derives wss via toWsUrl)
# After setting on Vercel, redeploy the frontend.
# Client diagnostic (unlisted): /dev/ws-probe
PUBLIC_GAME_SERVER_URL=

# Edge functions (solo servidor — configurar con npx @insforge/cli secrets set)
# INSFORGE_BASE_URL=
# ANON_KEY=
# INSFORGE_API_KEY=
# ROOM_CLEANUP_SECRET=

# --- services/game-server (InsForge Compute / local; never expose API key to browser) ---
# Set these on the Compute service (or local shell). Do not commit values.
# Production ALLOWED_ORIGINS must be exact origins — no wildcards.
# PORT=
# NODE_ENV=production
# ALLOWED_ORIGINS=https://your-app.example
# PUBLIC_APP_ORIGIN=https://your-app.example
# INSFORGE_BASE_URL=https://b963cy5n.us-east.insforge.app
# INSFORGE_API_KEY=          # server-only admin key
# WS_AUTH_MODE=insforge      # production auth mode (test forbidden in prod)
# WS_TEST_TOKEN=             # local only; ignored/rejected when NODE_ENV=production
# LOG_LEVEL=info
# After Compute HTTPS /health + WSS are healthy, set PUBLIC_GAME_SERVER_URL above
# to the public HTTPS base (client derives wss:// from the same host).
